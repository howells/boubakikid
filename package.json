{
  "name": "boubakikid",
  "version": "1.0.1",
  "description": "Pleasant, round ID generator based on bouba/kiki effect research",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "howells-lint",
    "format": "howells-format",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc,css}": "howells-format"
  },
  "keywords": [
    "nanoid",
    "id",
    "bouba",
    "kiki",
    "generator",
    "friendly"
  ],
  "author": "Daniel Howells",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/howells/boubakikid.git"
  },
  "homepage": "https://github.com/howells/boubakikid",
  "bugs": {
    "url": "https://github.com/howells/boubakikid/issues"
  },
  "dependencies": {
    "nanoid": "^5.1.7"
  },
  "devDependencies": {
    "@howells/lint": "*",
    "@howells/typescript-config": "*",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
